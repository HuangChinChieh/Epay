    <style>
        ::placeholder { color: black !important; opacity: 1; }
        button:hover { cursor: pointer; }
        * { font-family: 微軟正黑體, 微軟雅黑體, Arial; }
        .block-header {
            padding: 0 64px;
            margin-bottom: 16px;
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }
        .block-header h2 { color: #565d67; font-weight: bold; }
        .block-header .col { padding: 16px; }
        .card .body {
            font-size: 14px !important;
            color: #575b61 !important;
            padding: 0 20px !important;
        }
        .paper-wrap:before {
            content: "";
            position: absolute;
            top: 0; left: 0;
            border-width: 0 42px 42px 0;
            border-style: solid;
            border-color: #ffffff #253856;
            box-shadow: 0 0 0 rgba(0,0,0,0.4), 0 0 10px rgba(0,0,0,0.3);
            -webkit-transform: rotate(-90deg);
            transform: rotate(-90deg);
        }
        table { font-size: 14px !important; color: #575b61 !important; }
        .theme-cyan .btn-primary { background: #65C3DF; }
        .theme-cyan .btn-primary:active,
        .theme-cyan .btn-primary:hover,
        .theme-cyan .btn-primary:focus { background: #45B6B0; }
        #companySelectRow { padding: 16px 20px 8px; }
        #companySelectRow label { font-weight: bold; margin-right: 8px; font-size: 15px; }
        #sel_company { min-width: 320px; }

        /* 建單結果 overlay */
        #resultOverlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }
        #resultOverlay.active { display: flex; }
        #resultBox {
            background: #fff;
            border-radius: 8px;
            padding: 32px 40px;
            min-width: 500px;
            max-width: 700px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.25);
        }
        #resultBox h4 { font-weight: bold; margin-bottom: 20px; color: #253856; }
        #resultBox .info-row { margin-bottom: 10px; font-size: 14px; }
        #resultBox .info-row span.label-text { font-weight: bold; display: inline-block; width: 100px; }
