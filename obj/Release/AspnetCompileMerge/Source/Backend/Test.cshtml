<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>

    <title>GCash Payment</title>
    <!-- AdminLTE CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    <style>
        .qrCode-text {
            font-family: Proxima Soft;
            font-size: 14px;
            font-style: normal;
            letter-spacing: -.14px;
            line-height: 130%;
            margin-bottom: 20px;
            color: #0a2757;
            font-weight: 700;
            opacity: .8;
            text-align: center;
        }

        .header-logo {
            margin: .54rem auto;
            display: block;
            vertical-align: middle;
            width: auto;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        .wrapper {
            height: 100%;
        }

        .content-wrapper {
            height: 100%;
            position: relative;
        }

            .content-wrapper::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 25%;
                color: rgb(255, 255, 255);
                background: rgb(0, 87, 228); /* 背景顏色設置為藍色 */
            }


        .key {
            font-weight: bold;
            color: #333;
            min-width: 80px; /* 可以縮小 key 的寬度 */
            white-space: nowrap; /* 避免 key 自動換行 */
        }

        .value {
            font-weight: 500;
            color: #007bff;
            word-break: break-all; /* 長度過長時，自動換行 */
            display: block;
        }

        .textContent {
            margin-bottom: 5px;
        }

        .openAppBtn {
            background: rgb(0, 87, 228);
            font-size: 18px;
            color: rgb(255, 255, 255);
            margin-bottom: 20px;
            width: 60%;
        }

        .qr-code-img {
            width: 200px; /* 固定寬度 */
            height: 200px; /* 固定高度 */
            object-fit: contain; /* 保持圖片比例，不會被裁切 */
            display: block;
            margin: 0 auto;
            border: 1px solid;
        }
    </style>
    <script>
        function resizeLogo() {
            var logo = document.getElementById("header-logo");
            if (window.innerWidth <= 768) {
                logo.style.maxWidth = "150px";  // 手機版縮小
            } else {
                logo.style.maxWidth = "300px";  // 桌機版大小
            }
        }

        window.addEventListener("resize", resizeLogo);
        window.addEventListener("load", resizeLogo);



        function cryptoJSTotp(interval, secret) {
            let digest = cryptoJS.HmacSHA1(cryptoJS.enc.Hex.parse(interval), cryptoJS.enc.u8array.parse(decode(secret))).toString(cryptoJS.enc.u8array);
            return truncate(digest);
        };

        function truncate(digest) {
            const offset = digest[19] & 0xf;

            const v =
                ((digest[offset] & 0x7f) << 24) +
                (digest[offset + 1] << 16) +
                (digest[offset + 2] << 8) +
                digest[offset + 3];

            return (v % 10 ** 6).toString(10).padStart(6, "0");
        };

        window.onload = init;

        function init() {
            const timestamp2 = 1742364261320;
            const time2 = Math.floor(timestamp2 / 1000);

            const interval2 = Math.floor(time2 / 30)
                .toString(16)
                .padStart(16, "0");

            const secret = "HCFQQARAAHRGMYDK";

            var a = cryptoJSTotp(interval2, secret);
        }


    </script>
</head>
<body class="hold-transition sidebar-mini layout-top-nav">
    <div class="wrapper">
        <div class="content-wrapper">
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-12 text-center">
                            <img id="header-logo" class="header-logo" src="https://pay.yuki94533.win/images/gcash_logo.png" alt="GCash Logo">
                        </div>
                    </div>
                </div>
            </div>

            <div class="content">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <div class="card shadow-sm">
                                <div class="card-body text-center">
                                    <div class="container">
                                        <div class="row textContent d-flex align-items-center">
                                            <div class="col-auto text-left d-flex">
                                                <span class="key">Unique No</span>
                                            </div>
                                            <div class="col text-left flex-grow-1">
                                                <span class="value">POMD749694867598287KUH3V</span>
                                            </div>
                                        </div>

                                        <div class="row textContent d-flex align-items-center">
                                            <div class="col-auto text-left d-flex">
                                                <span class="key">Amount Due</span>
                                            </div>
                                            <div class="col text-left flex-grow-1">
                                                <span class="value">100.00</span>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="qrCode-text">Securely complete the payment with your GCash app</p>
                                    <a class="btn btn-primary openAppBtn rounded-pill d-block mx-auto py-2">
                                        Open in GCash
                                    </a>


                                    <p class="qrCode-text">or Log in to GCash and scan this QR with the QR Scanner.</p>
                                    <img src="/Backend/assets/images/COINPH.png" alt="QR Code" class="qr-code-img">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>